{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "category", "scenario", "question", "reference_scores", "scoring_tolerance", "explanation"],
    "additionalProperties": true,
    "properties": {
      "id": {"type": "string", "pattern": "^C3-\\d{3}$"},
      "category": {"type": "string", "const": "C3"},
      "scenario": {"type": "string", "minLength": 10},
      "question": {"type": "string", "minLength": 5},
      "reference_scores": {
        "type": "object",
        "required": ["S", "K", "O", "D"],
        "properties": {
          "S": {"type": "integer", "minimum": 0, "maximum": 5},
          "K": {"type": "integer", "minimum": 0, "maximum": 5},
          "O": {"type": "integer", "minimum": 0, "maximum": 5},
          "D": {"type": "integer", "minimum": 0, "maximum": 5}
        }
      },
      "scoring_tolerance": {"type": "integer", "minimum": 0, "maximum": 5},
      "explanation": {"type": "string"}
    }
  }
}
