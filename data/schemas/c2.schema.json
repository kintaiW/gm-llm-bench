{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "category", "question", "options", "answer"],
    "additionalProperties": true,
    "properties": {
      "id": {"type": "string", "pattern": "^C2-\\d{3}$"},
      "category": {"type": "string", "const": "C2"},
      "question": {"type": "string", "minLength": 5},
      "options": {
        "type": "array",
        "minItems": 2,
        "items": {"type": "string"}
      },
      "answer": {"type": "string", "pattern": "^G[MB]/T\\s*\\d{4,5}(-\\d{4})?$"},
      "explanation": {"type": "string"}
    }
  }
}
