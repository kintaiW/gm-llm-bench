{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "category", "scenario", "question", "options", "answer", "severity", "explanation"],
    "additionalProperties": true,
    "properties": {
      "id": {"type": "string", "pattern": "^C4-\\d{3}$"},
      "category": {"type": "string", "const": "C4"},
      "scenario": {"type": "string", "minLength": 10},
      "question": {"type": "string", "minLength": 5},
      "options": {
        "type": "object",
        "required": ["A", "B", "C", "D"],
        "properties": {
          "A": {"type": "string"},
          "B": {"type": "string"},
          "C": {"type": "string"},
          "D": {"type": "string"}
        }
      },
      "answer": {
        "type": "array",
        "items": {"type": "string", "enum": ["A", "B", "C", "D"]},
        "minItems": 1,
        "uniqueItems": true
      },
      "severity": {
        "type": "object",
        "additionalProperties": {
          "type": "string",
          "enum": ["严重", "一般", "轻微"]
        }
      },
      "explanation": {"type": "string"}
    }
  }
}
