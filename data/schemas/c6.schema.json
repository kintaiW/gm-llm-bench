{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "category", "scenario", "expected_tool_sequence", "acceptable_alternatives", "scoring"],
    "additionalProperties": true,
    "properties": {
      "id": {"type": "string", "pattern": "^C6-\\d{3}$"},
      "category": {"type": "string", "const": "C6"},
      "scenario": {"type": "string", "minLength": 10},
      "expected_tool_sequence": {
        "type": "array",
        "items": {"type": "string"},
        "minItems": 1
      },
      "acceptable_alternatives": {
        "type": "array",
        "items": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "scoring": {
        "type": "object",
        "required": ["exact_match", "acceptable", "partial_sequence", "wrong_tool"],
        "properties": {
          "exact_match": {"type": "number"},
          "acceptable": {"type": "number"},
          "partial_sequence": {"type": "number"},
          "wrong_tool": {"type": "number"}
        }
      }
    }
  }
}
